{
  "installCommand": "npm install --ignore-scripts",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/client",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://phuket-smart-bus.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
