{
  "name": "phuket-smart-bus-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:web:test": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "dev:api": "tsx watch server/index.ts",
    "dev:api:test": "tsx server/index.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "dev:worker:test": "tsx server/worker.ts",
    "typecheck": "npm run typecheck:server && npm run typecheck:app && npm run typecheck:test",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "npm run start:web",
    "start:web": "node dist/server/server/index.js",
    "start:worker": "node dist/server/server/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:mocked && npm run test:e2e:live",
    "test:e2e:mocked": "playwright test e2e/mocked-ui.spec.ts",
    "test:e2e:live": "playwright test e2e/live-api.spec.ts",
    "verify": "npm run typecheck && npm test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "leaflet": "^1.9.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "socket.io-client": "^4.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "concurrently": "^9.1.2",
    "jsdom": "^26.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
